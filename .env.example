NODE_ENV=local
PORT=4000

# Host: 127.0.0.1 con `npm run start:dev`. Dentro de Docker Compose (api): DB_HOST=db
DB_HOST=127.0.0.1
# 5433 evita choque si fintrack-api ya ocupa 5432 en Docker
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=terminalops

# Angular dev server (CORS)
ORIGIN=http://localhost:4200

JWT_SECRET=dev-terminalops-jwt-secret-change-me
JWT_REFRESH_SECRET=dev-terminalops-refresh-secret-change-me
SALT_ROUNDS=10
